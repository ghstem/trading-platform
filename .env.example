# Trading Platform - Environment Configuration Template
# Copy this file to .env and fill in your API keys and settings

# ==================== BROKER APIS ====================
# Interactive Brokers
IB_ACCOUNT_ID=your_ib_account_id
IB_HOST=127.0.0.1
IB_PORT=7497

# OANDA Forex
OANDA_API_KEY=your_oanda_api_key
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_ENVIRONMENT=practice  # or 'live'

# Alpaca (Stocks/Options)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # or 'https://api.alpaca.markets' for live

# Robinhood
ROBINHOOD_USERNAME=your_robinhood_email
ROBINHOOD_PASSWORD=your_robinhood_password
ROBINHOOD_MFA_CODE=your_mfa_code

# ==================== CRYPTOCURRENCY EXCHANGES ====================
# Coinbase
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_SECRET_KEY=your_coinbase_secret_key
COINBASE_PASSPHRASE=your_coinbase_passphrase

# Binance
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# Kraken
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_SECRET_KEY=your_kraken_secret_key

# ==================== FINANCIAL DATA PROVIDERS ====================
# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Quandl
QUANDL_API_KEY=your_quandl_api_key

# Yahoo Finance (No API key needed)
YAHOO_FINANCE_ENABLED=true

# ==================== SPORTS BETTING APIS ====================
# SportsRadar
SPORTSRADAR_API_KEY=your_sportsradar_key

# The Odds API
ODDS_API_KEY=your_odds_api_key

# Betfair
BETFAIR_USERNAME=your_betfair_username
BETFAIR_PASSWORD=your_betfair_password
BETFAIR_APP_KEY=your_betfair_app_key

# ==================== DATABASE CONFIGURATION ====================
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_platform
DB_USER=trading_user
DB_PASSWORD=your_secure_password

# MongoDB (for caching/alternative storage)
MONGO_URI=mongodb://localhost:27017/trading_platform

# Redis (for caching and scheduling)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==================== PLATFORM SETTINGS ====================
# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=true

# Flask/API Server
FLASK_SECRET_KEY=your_secret_key_here
API_HOST=0.0.0.0
API_PORT=5000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trading_platform.log

# ==================== TRADING PARAMETERS ====================
# Risk Management
DEFAULT_RISK_PERCENTAGE=2.0  # Risk per trade as % of account
MAX_POSITION_SIZE=0.1  # Max position as % of account
MAX_DAILY_LOSS=-1000  # Stop trading if daily loss exceeds this

# Backtesting
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-01-01
INITIAL_CAPITAL=100000

# ==================== MARKET DATA ====================
# Update frequency (in seconds)
MARKET_DATA_UPDATE_INTERVAL=60
INTRADAY_DATA_UPDATE_INTERVAL=5

# Asset classes to track
ENABLED_ASSET_CLASSES=stocks,crypto,forex,options,futures

# ==================== MACHINE LEARNING ====================
# RL Agent Settings
RL_LEARNING_RATE=0.001
RL_BATCH_SIZE=32
RL_EPISODES=1000
RL_EPSILON_DECAY=0.995

# Alpha Factor Settings
ALPHA_WINDOW=20
ALPHA_MIN_CORRELATION=0.3

# ==================== NOTIFICATIONS ====================
# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=your_email@gmail.com

# Discord Webhook (for alerts)
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ==================== SECURITY ====================
# JWT/Auth
JWT_SECRET_KEY=your_jwt_secret_key
JWT_EXPIRATION_HOURS=24

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600  # seconds

# ==================== WALLET & BLOCKCHAIN ====================
# Ethereum/Web3
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/your_infura_key
PRIVATE_KEY=your_wallet_private_key
WALLET_ADDRESS=your_wallet_address

# ==================== DEVELOPMENT ====================
# Testing
TESTING=false
TEST_DATABASE_URL=sqlite:///:memory:

# Feature Flags
ENABLE_LIVE_TRADING=false
ENABLE_SPORTS_BETTING=true
ENABLE_DEFI_INTEGRATION=false
